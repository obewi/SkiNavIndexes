{
  "$schema": "https://opencode.ai/config.json",
	"mcp": {
		"cupertino": {
			"type": "local",
			"command": [
				"/opt/homebrew/bin/cupertino",
				"serve"
			]
		},
		"XcodeBuildMCP": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"xcodebuildmcp@latest"
			]
		},
		"axiom": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"axiom-mcp@latest"
			]
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true
		},
		"gh_grep": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		},
	},
	"plugin": ["@knikolov/opencode-plugin-simple-memory", "opencode-handoff"]
}