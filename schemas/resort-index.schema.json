{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkiNav Resort Discovery Index",
  "type": "object",
  "required": [
    "version",
    "datasetVersion",
    "schemaVersion",
    "generated_at",
    "total_resorts",
    "regions",
    "resorts"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "datasetVersion": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_resorts": {
      "type": "integer",
      "minimum": 0
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resorts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resort"
      }
    }
  },
  "$defs": {
    "resort": {
      "type": "object",
      "required": [
        "id",
        "name",
        "names",
        "type",
        "bbox",
        "area_km2",
        "groupId",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "type": {
          "type": "string",
          "enum": ["domain", "resort"]
        },
        "parent_id": {
          "type": ["string", "null"]
        },
        "parent_name": {
          "type": ["string", "null"]
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          },
          "description": "[west, south, east, north] in decimal degrees"
        },
        "area_km2": {
          "type": "number",
          "minimum": 0
        },
        "country": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{2}$"
        },
        "groupId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["operating", "unknown"]
        }
      },
      "additionalProperties": true
    }
  }
}
