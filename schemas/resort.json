{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ski Resort Index",
  "type": "object",
  "required": ["version", "generated_at", "total_resorts", "resorts"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_resorts": {
      "type": "integer",
      "minimum": 0
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resorts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/resort"
      }
    }
  },
  "definitions": {
    "resort": {
      "type": "object",
      "required": ["id", "name", "names", "bbox", "area_km2"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "OSM ID (positive for ways, negative for relations)"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Primary display name"
        },
        "names": {
          "type": "array",
          "minItems": 1,
          "description": "All searchable name variants",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "geometry": {
          "type": "object",
          "description": "GeoJSON Polygon geometry (optional, may be null for some entries)",
          "properties": {
            "type": {
              "const": "Polygon"
            },
            "coordinates": {
              "type": "array"
            }
          }
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          },
          "description": "[west, south, east, north] in decimal degrees"
        },
        "area_km2": {
          "type": "number",
          "minimum": 0
        },
        "country": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{2}$"
        },
        "site_relation_ids": {
          "type": "array",
          "description": "IDs of site=piste relations that contain this area",
          "items": {
            "type": "integer"
          }
        },
        "contained_area_ids": {
          "type": "array",
          "description": "IDs of landuse=winter_sports areas within this relation",
          "items": {
            "type": "integer"
          }
        }
      }
    }
  }
}
